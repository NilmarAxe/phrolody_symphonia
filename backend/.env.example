# Application
NODE_ENV=development
PORT=4000
API_PREFIX=/api
APP_NAME=Phrolody Symphonia

# Database
DATABASE_URL=postgresql://phrolody_user:phrolody_password@localhost:5432/phrolody_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=30d

# OAuth Providers (optional for initial development)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=audio-files

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_AUDIO_FORMATS=mp3,flac,wav,aac,ogg

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# WebSocket
WS_PORT=4001
WS_PATH=/ws

# Email (optional for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@phrolodysymphonia.com

# Monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Machine Learning (optional for recommendations)
ML_MODEL_PATH=./models
ML_ENABLE=false