{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.json",
    "assets": [
      {
        "include": "**/*.prisma",
        "outDir": "./dist",
        "watchAssets": true
      },
      {
        "include": "i18n/**/*",
        "outDir": "./dist",
        "watchAssets": true
      }
    ],
    "watchAssets": true
  },
  "monorepo": false,
  "root": ".",
  "entryFile": "main",
  "projects": {},
  "generateOptions": {
    "spec": true,
    "flat": false
  }
}